# ============================================
# 📋 Environment Configuration Template
# ============================================
# Copy file này thành .env.development hoặc .env.production
# rồi điền các giá trị phù hợp cho môi trường tương ứng.
#
# 🔑 KHÔNG COMMIT file .env.* chứa secret thật lên git!

# Server
NODE_ENV=development
PORT=3000
LOG_LEVEL=debug

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ehealthdatabase
DB_USER=postgres
DB_PASSWORD=

# JWT (Nên dùng secret random ≥ 32 ký tự)
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=

# Frontend URL
FRONTEND_URL=http://localhost:3000

# Email
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Firebase (JSON string)
FIREBASE_SERVICE_ACCOUNT='{}'

# SePay Payment Gateway
SEPAY_MERCHANT_ID=
SEPAY_API_KEY=
SEPAY_WEBHOOK_SECRET=
SEPAY_ENVIRONMENT=SANDBOX
SEPAY_BANK_ACCOUNT=
SEPAY_BANK_NAME=
SEPAY_ACCOUNT_HOLDER=
SEPAY_VA_ACCOUNT=

# AI
GEMINI_API_KEY=
OPENAI_API_KEY=
